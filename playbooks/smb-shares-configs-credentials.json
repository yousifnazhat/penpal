{
  "actions": [
    {
      "commands": [
        "smbclient -L //<target_host> -N",
        "smbclient -L //<target_host> -U <known_user>"
      ],
      "description": "Enumerate SMB shares and permissions before downloading anything.",
      "id": "enumerate-smb-shares",
      "risk": "normal"
    },
    {
      "commands": [
        "grep -RniE \"pass|user|cred|key|token|secret|connection\" loot/",
        "python -m penpal ingest <target_name> --file ./smb-loot-review.txt --source smb-loot-review --service tcp/445"
      ],
      "description": "Review only relevant readable files for configs, scripts, backups, hostnames, users, and credential-looking strings.",
      "id": "review-readable-smb-files",
      "risk": "passive"
    }
  ],
  "description": "Use readable SMB shares to find configuration and identity facts, then feed confirmed evidence back into PenPal.",
  "id": "smb-shares-configs-credentials",
  "safety": {
    "authorized_use_only": true,
    "requires_operator_approval": true
  },
  "schema": "penpal-playbook-v1",
  "signals": [
    {
      "ports": [
        139,
        445
      ],
      "type": "service_any"
    }
  ],
  "tags": [
    "smb",
    "shares",
    "configs",
    "credentials"
  ],
  "title": "SMB shares to configs and credentials"
}
